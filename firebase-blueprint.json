{
  "entities": {
    "Entry": {
      "title": "Entry",
      "description": "A stock entry record",
      "type": "object",
      "properties": {
        "mes": { "type": "string" },
        "chave_acesso": { "type": "string" },
        "nf_numero": { "type": "string" },
        "tonelada": { "type": "number" },
        "valor": { "type": "number" },
        "descricao_produto": { "type": "string" },
        "data_nf": { "type": "string" },
        "data_descarga": { "type": "string" },
        "status": { "type": "string" },
        "fornecedor": { "type": "string" },
        "placa_veiculo": { "type": "string" },
        "container": { "type": "string" },
        "destino": { "type": "string" },
        "data_posicionamento": { "type": "string" },
        "data_faturamento_vli": { "type": "string" },
        "horario_posicionamento": { "type": "string" },
        "horario_faturamento": { "type": "string" },
        "numero_vagao": { "type": "string" },
        "hora_chegada": { "type": "string" },
        "hora_entrada": { "type": "string" },
        "hora_saida": { "type": "string" },
        "data_emissao_nf": { "type": "string" },
        "cte_intertex": { "type": "string" },
        "data_emissao_cte": { "type": "string" },
        "cte_transportador": { "type": "string" },
        "import_batch": { "type": "string" },
        "branchId": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["nf_numero", "fornecedor", "status", "branchId"]
    },
    "Container": {
      "title": "Container",
      "description": "A physical container record",
      "type": "object",
      "properties": {
        "numero": { "type": "string" },
        "status": { "type": "string", "enum": ["Disponível", "Em Manutenção", "Em Uso"] },
        "observacao": { "type": "string" },
        "branchId": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" },
        "updated_by_email": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["numero", "status", "branchId"]
    },
    "Branch": {
      "title": "Branch",
      "description": "A company branch or location",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "code": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["name", "code"]
    }
  },
  "firestore": {
    "entries": {
      "schema": "Entry",
      "description": "Collection of stock entries"
    },
    "containers": {
      "schema": "Container",
      "description": "Collection of physical containers"
    },
    "branches": {
      "schema": "Branch",
      "description": "Collection of company branches"
    }
  }
}
