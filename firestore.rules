rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: entries
    // Document ID: auto-generated
    // Fields:
    //   - mes: string
    //   - chave_acesso: string
    //   - nf_numero: string (required)
    //   - tonelada: number
    //   - valor: number
    //   - descricao_produto: string
    //   - data_nf: string
    //   - data_descarga: string
    //   - status: string (required)
    //   - fornecedor: string (required)
    //   - placa_veiculo: string
    //   - container: string
    //   - destino: string
    //   - data_posicionamento: string
    //   - data_faturamento_vli: string
    //   - horario_posicionamento: string
    //   - horario_faturamento: string
    //   - numero_vagao: string
    //   - hora_chegada: string
    //   - hora_entrada: string
    //   - hora_saida: string
    //   - data_emissao_nf: string
    //   - cte_intertex: string
    //   - data_emissao_cte: string
    //   - cte_transportador: string
    //   - import_batch: string
    //   - branchId: string (required)
    //   - created_at: string
    //   - uid: string (required)
    //
    // Collection: containers
    // Document ID: auto-generated
    // Fields:
    //   - numero: string (required)
    //   - status: string (required) - ["Disponível", "Em Manutenção", "Em Uso"]
    //   - observacao: string
    //   - branchId: string (required)
    //   - updated_at: timestamp
    //   - updated_by_email: string
    //   - uid: string (required)
    //
    // Collection: branches
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - location: string
    //   - code: string (required)
    //   - created_at: timestamp
    //   - uid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "massote1984@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidEntry(data) {
      return data.keys().hasAll(['nf_numero', 'fornecedor', 'status', 'uid', 'branchId']) &&
             data.nf_numero is string &&
             data.fornecedor is string &&
             data.status is string &&
             data.uid is string &&
             data.branchId is string;
    }

    function isValidContainer(data) {
      return data.keys().hasAll(['numero', 'status', 'uid', 'branchId']) &&
             data.numero is string && data.numero.size() > 0 &&
             data.status in ["Disponível", "Em Manutenção", "Em Uso"] &&
             data.uid is string &&
             data.branchId is string;
    }

    function isValidBranch(data) {
      return data.keys().hasAll(['name', 'code', 'uid']) &&
             data.name is string && data.name.size() > 0 &&
             data.code is string && data.code.size() > 0 &&
             data.uid is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBranch(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isValidBranch(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isAdmin();
    }

    match /entries/{entryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidEntry(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isValidEntry(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /containers/{containerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidContainer(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isValidContainer(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }
  }
}
